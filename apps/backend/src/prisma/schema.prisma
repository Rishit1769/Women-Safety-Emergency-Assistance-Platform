// -----------------------------------------------------------------
// RBAC � ORGANIZATIONS, WORKERS, AUDIT LOGS
// -----------------------------------------------------------------

model Organization {
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationName String             @map("organization_name") @db.VarChar(200)
  organizationType OrganizationType   @map("organization_type")
  description      String?
  email            String?            @unique @db.VarChar(150)
  phone            String?            @db.VarChar(15)
  address          String?
  city             String?            @db.VarChar(100)
  state            String?            @db.VarChar(100)
  pincode          String?            @db.VarChar(10)
  logoUrl          String?            @map("logo_url")
  status           OrganizationStatus @default(pending)
  createdById      String             @map("created_by_id") @db.Uuid
  approvedAt       DateTime?          @map("approved_at")
  suspendedAt      DateTime?          @map("suspended_at")
  suspendReason    String?            @map("suspend_reason")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  createdBy User     @relation("org_created_by", fields: [createdById], references: [id])
  workers   Worker[]

  @@index([status], name: "idx_organizations_status")
  @@index([organizationType], name: "idx_organizations_type")
  @@map("organizations")
}

model Worker {
  id             String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId         String?    @unique @map("user_id") @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  workerType     WorkerType @map("worker_type")
  customRole     String?    @map("custom_role") @db.VarChar(100)
  email          String     @unique @db.VarChar(150)
  passwordHash   String     @map("password_hash")
  fullName       String     @map("full_name") @db.VarChar(100)
  phone          String?    @db.VarChar(15)
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId], name: "idx_workers_org_id")
  @@index([email], name: "idx_workers_email")
  @@map("workers")
}

model AuditLog {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  actorRole  UserRole? @map("actor_role")
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation("audit_actor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId], name: "idx_audit_logs_actor")
  @@index([action], name: "idx_audit_logs_action")
  @@index([createdAt(sort: Desc)], name: "idx_audit_logs_created")
  @@map("audit_logs")
}
